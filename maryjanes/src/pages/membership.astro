---
import Base from "../layouts/Base.astro";
import site from "../content/site/settings.json";
---

<Base
  title="Membership — Mary Jane's Place"
  description="Three membership tiers for prescribed medical cannabis patients in the UK. Free access for every verified patient; paid tiers fund the national network. Verified once with a prescription — no paperwork after."
>
  <section class="ph-top pad">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Membership</div>
      <h1 class="rv">Every verified patient is a member.</h1>
      <p class="rv lede" style="margin-top:16px">
        {site.membership.intro} Whichever tier you choose, you're part of building Britain's
        first patient-led sanctuary network.
      </p>
    </div>
  </section>

  <section class="pad-sm" style="padding-top:0">
    <div class="wrap">
      <div class="tiers rv">
        {site.membership.tiers.map((t) => (
          <div class={"tier" + (t.primary ? " tier--primary" : "")}>
            {t.primary && <div class="tier-badge">Most chosen</div>}
            <div class="eyebrow" style={t.primary ? "color:var(--sage-soft)" : ""}>{t.name}</div>
            <div class="tier-price">
              <span class={"tier-amount" + (t.price.startsWith("£") || t.price === "Free" ? "" : " tier-amount--text")}>{t.price}</span>
              <span class="tier-freq">{t.frequency}</span>
            </div>
            <p class="tier-tag">{t.tagline}</p>
            <ul class="checks tier-feats">
              {t.features.map((f) => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg>
                  <span set:html={f}></span>
                </li>
              ))}
            </ul>
            <a class={"btn" + (t.primary ? "" : " ghost")} href={`/visit#contact?tier=${t.id}`} style="width:100%;justify-content:center;margin-top:6px">{t.cta} <span class="arr">→</span></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap">
      <div class="callout rv">
        <div>
          <div class="eyebrow">Reassurance</div>
          <h3 style="margin-top:6px">Verified once. Never asked again.</h3>
          <p>
            We check your photo ID and proof of prescription (dispensing label or letter,
            within six months) one time, when you first join. Your details are stored securely
            and never shared with clinics, employers, the police or anyone else without your
            consent or a lawful requirement.
          </p>
        </div>
        <a class="btn" href="/your-rights">Your rights, in plain English <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Common questions</div>
      <div class="rv" style="margin-top:14px;border-top:1px solid var(--line)">
        <details class="acc-item">
          <summary>How does verification work?</summary>
          <div>
            You show photo ID (passport, driving licence or PASS card) plus proof of a current
            prescription — either the dispensing label on your original pharmacy packaging, or
            a prescriber letter dated within the last six months. We check, log that you're
            verified, and you don't need to do it again.
          </div>
        </details>
        <details class="acc-item">
          <summary>What happens to my prescription details?</summary>
          <div>
            We don't keep copies of your prescription. We record only the minimum needed to
            confirm you're a verified patient: your name, date of verification, prescriber's
            clinic name and the date your proof expires. That's it. We are not a clinic and
            we don't share information with one.
          </div>
        </details>
        <details class="acc-item">
          <summary>Can I switch tiers later?</summary>
          <div>
            Of course. Upgrade, downgrade or cancel any time from your member account.
            The free Patient Member tier is always available; there's no penalty for stepping
            up to Plus or Founding and then back again as life happens.
          </div>
        </details>
        <details class="acc-item">
          <summary>How are my payments handled?</summary>
          <div>
            Paid tiers will use Stripe's secure card processing when we launch them — a
            standard, audited UK payment provider. Stripe charges only when you successfully
            pay. There are no setup fees, no platform fees, and you can stop your subscription
            at any time. We are committed to no hidden costs, ever.
          </div>
        </details>
        <details class="acc-item">
          <summary>I don't have a prescription yet — can I still come along?</summary>
          <div>
            Yes. Anyone over 18 is welcome to visit, buy a drink and chat to us about how the
            UK system works — we'll happily talk you through clinics, costs and what to expect.
            Only the act of using your medicine here requires verification.
          </div>
        </details>
      </div>
      <div class="disc rv" style="margin-top:24px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <div>
          Paid tiers are currently registering interest. We're launching with a small founding
          cohort first, then opening to all members. Sign up via "Apply to join" and we'll
          email you when it's your turn.
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    align-items: stretch;
  }
  .tier {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--r);
    padding: 32px 28px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: 0.25s;
  }
  .tier:hover { box-shadow: var(--shadow); transform: translateY(-3px); }
  .tier--primary {
    background: var(--olive-d);
    color: #fff;
    border-color: var(--olive-d);
    box-shadow: 0 20px 50px -28px rgba(16, 59, 20, 0.6);
  }
  .tier--primary .eyebrow,
  .tier--primary p.tier-tag,
  .tier--primary .tier-feats li,
  .tier--primary .tier-freq { color: rgba(255, 255, 255, 0.85); }
  .tier--primary .tier-amount,
  .tier--primary .tier-feats li b { color: #fff; }
  .tier--primary .checks li svg { color: var(--sage-soft); }
  .tier--primary .btn.ghost,
  .tier--primary .btn {
    background: #fff;
    color: var(--olive-d);
    border-color: #fff;
  }
  .tier--primary .btn:hover {
    background: var(--cream);
    border-color: var(--cream);
  }
  .tier-badge {
    position: absolute;
    top: -12px;
    right: 22px;
    background: var(--olive);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 6px 12px;
    border-radius: 20px;
    text-transform: uppercase;
  }
  .tier-price { margin: 14px 0 4px; display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .tier-amount {
    font-size: 38px;
    font-weight: 800;
    color: var(--olive-d);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tier-amount--text {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .tier--primary .tier-amount--text { color: #fff; }
  .tier-freq { font-size: 13.5px; color: var(--ink-soft); }
  .tier-tag {
    font-size: 15px;
    margin-bottom: 18px;
    min-height: 46px;
  }
  .tier-feats { margin-bottom: 22px; flex: 1; }
  .tier-feats li { font-size: 14.5px; }

  .acc-item { border-bottom: 1px solid var(--line); }
  .acc-item summary {
    list-style: none; cursor: pointer; padding: 19px 2px;
    display: flex; justify-content: space-between; gap: 16px; align-items: center;
    font-family: var(--font); font-size: 18px; font-weight: 700; color: var(--olive-d);
  }
  .acc-item summary::-webkit-details-marker { display: none; }
  .acc-item summary::after {
    content: "+"; flex: none; width: 24px; height: 24px; border-radius: 6px;
    border: 1.5px solid var(--line); display: grid; place-items: center;
    transition: 0.25s; font-size: 17px; color: var(--olive); line-height: 1;
  }
  .acc-item[open] summary::after {
    background: var(--olive); border-color: var(--olive); color: #fff; transform: rotate(45deg);
  }
  .acc-item > div { padding: 0 2px 20px; color: var(--ink-soft); font-size: 16px; max-width: 74ch; }

  @media (max-width: 980px) { .tiers { grid-template-columns: 1fr; } }
</style>
