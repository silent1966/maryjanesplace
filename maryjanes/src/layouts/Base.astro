---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../content/site/settings.json";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Mary Jane's Place — A private sanctuary for prescribed medical cannabis patients · Bournemouth",
  description = "Mary Jane's Place is a private sanctuary in Bournemouth where prescribed medical cannabis patients can use their medicine without judgment. Legal, vaporiser-friendly, prescription required. Clear information on medical cannabis, the law and your rights.",
  ogImage = "/logo.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#103B14" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mary Jane's Place" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://maryjanesplace.co.uk/#org",
          "name": site.brand.name,
          "url": "https://maryjanesplace.co.uk",
          "logo": "https://maryjanesplace.co.uk/logo.png",
          "description": "Britain's first patient sanctuary for prescribed medical cannabis. A flagship in Bournemouth, with a national network in development.",
          "sameAs": [site.social.instagram, site.social.facebook],
          "contactPoint": [{
            "@type": "ContactPoint",
            "telephone": site.contact.phoneIntl,
            "email": site.contact.email,
            "contactType": "customer service",
            "areaServed": "GB",
            "availableLanguage": "en"
          }]
        },
        {
          "@type": "LocalBusiness",
          "@id": "https://maryjanesplace.co.uk/#place",
          "name": site.brand.name + " — Bournemouth",
          "parentOrganization": { "@id": "https://maryjanesplace.co.uk/#org" },
          "url": "https://maryjanesplace.co.uk",
          "telephone": site.contact.phoneIntl,
          "email": site.contact.email,
          "image": "https://maryjanesplace.co.uk/logo.png",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": site.contact.address.line1,
            "addressLocality": site.contact.address.city,
            "postalCode": site.contact.address.postcode,
            "addressCountry": "GB"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": site.contact.address.lat,
            "longitude": site.contact.address.lng
          },
          "sameAs": [site.social.instagram, site.social.facebook]
        }
      ]
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
