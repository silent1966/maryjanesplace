---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../content/site/settings.json";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Mary Jane's Place — A safe space for medical cannabis patients · Bournemouth",
  description = "Mary Jane's Place is a safe space for medical cannabis patients in Bournemouth. A members' space where prescribed patients can use their medicine, with the information, community and equipment that should come with it.",
  ogImage = "/logo.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#103B14" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mary Jane's Place" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://maryjanesplace.co.uk/#website",
          "url": "https://maryjanesplace.co.uk",
          "name": "Mary Jane's Place",
          "description": "A safe space for UK medical cannabis patients",
          "publisher": { "@id": "https://maryjanesplace.co.uk/#org" },
          "inLanguage": "en-GB",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://maryjanesplace.co.uk/shop?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://maryjanesplace.co.uk/#org",
          "name": site.brand.name,
          "url": "https://maryjanesplace.co.uk",
          "logo": {
            "@type": "ImageObject",
            "url": "https://maryjanesplace.co.uk/logo.png",
            "width": 760,
            "height": 307
          },
          "description": "A safe space for medical cannabis patients. Located in Bournemouth, serving the UK community.",
          "sameAs": [site.social.instagram, site.social.facebook, site.social.googleMaps],
          "knowsAbout": [
            "Medical cannabis",
            "UK medical cannabis prescriptions",
            "Cannabis-based medicinal products",
            "Dry herb vaporisers",
            "Patient rights and police guidance",
            "NPCC medicinal cannabis guidance",
            "Misuse of Drugs Regulations 2018",
            "Bournemouth medical cannabis"
          ],
          "contactPoint": [{
            "@type": "ContactPoint",
            "telephone": site.contact.phoneIntl,
            "email": site.contact.email,
            "contactType": "customer service",
            "areaServed": "GB",
            "availableLanguage": "en"
          }]
        },
        {
          "@type": "LocalBusiness",
          "@id": "https://maryjanesplace.co.uk/#place",
          "name": site.brand.name + " — Bournemouth",
          "parentOrganization": { "@id": "https://maryjanesplace.co.uk/#org" },
          "url": "https://maryjanesplace.co.uk",
          "telephone": site.contact.phoneIntl,
          "email": site.contact.email,
          "image": "https://maryjanesplace.co.uk/logo.png",
          "priceRange": "££",
          "currenciesAccepted": "GBP",
          "paymentAccepted": "Cash, Credit Card, Debit Card",
          "areaServed": [
            { "@type": "Country", "name": "United Kingdom" },
            { "@type": "City", "name": "Bournemouth" }
          ],
          "isAccessibleForFree": false,
          "hasMap": site.contact.googleMapsUrl,
          "address": {
            "@type": "PostalAddress",
            "streetAddress": site.contact.address.line1,
            "addressLocality": site.contact.address.city,
            "postalCode": site.contact.address.postcode,
            "addressCountry": "GB"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": site.contact.address.lat,
            "longitude": site.contact.address.lng
          },
          "openingHoursSpecification": [
            { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Wednesday","Thursday","Friday","Sunday"], "opens": "08:30", "closes": "14:30" },
            { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Wednesday","Thursday","Friday","Sunday"], "opens": "17:30", "closes": "20:30" },
            { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:30", "closes": "14:30" },
            { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "17:30", "closes": "22:30" }
          ],
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5.0",
            "reviewCount": "2",
            "bestRating": "5",
            "worstRating": "1"
          },
          "sameAs": [site.social.instagram, site.social.facebook, site.social.googleMaps]
        }
      ]
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <div id="age-gate" class="age-gate" hidden>
      <div class="age-gate-card">
        <div class="age-gate-eyebrow">Age verification</div>
        <h2>This site is for adults aged 18 and over.</h2>
        <p>Mary Jane's Place is a UK members' space and shop for prescribed medical cannabis patients. The products and information here are intended only for adults 18+. By continuing you confirm you are 18 or over.</p>
        <div class="age-gate-actions">
          <button class="btn" id="age-yes" type="button">I am 18 or over — continue</button>
          <a class="btn ghost" href="https://www.nhs.uk" rel="noopener">Take me away</a>
        </div>
        <p class="age-gate-fine">We will remember this choice on this browser. See our <a href="/privacy">privacy policy</a> and <a href="/terms">terms</a>.</p>
      </div>
    </div>
    <script>
      (function() {
        try {
          var key = 'mjp-age-ok';
          if (!sessionStorage.getItem(key) && !localStorage.getItem(key)) {
            var g = document.getElementById('age-gate');
            if (g) {
              g.hidden = false;
              document.body.style.overflow = 'hidden';
            }
            var btn = document.getElementById('age-yes');
            btn && btn.addEventListener('click', function() {
              try { localStorage.setItem(key, '1'); } catch(e) { sessionStorage.setItem(key, '1'); }
              if (g) g.hidden = true;
              document.body.style.overflow = '';
            });
          }
        } catch(e) {}
      })();
    </script>
  </body>
</html>
