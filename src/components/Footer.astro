---
import site from "../content/site/settings.json";
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <a class="brand" href="/" aria-label="Mary Jane's Place — home" style="margin-bottom:4px">
          <img class="brand-logo brand-logo--foot" src="/logo.png" alt="Mary Jane's Place" width="220" height="90" />
        </a>
        <p class="fdesc">A safe space for medical cannabis patients. We're in Bournemouth — the community is UK-wide.</p>
        <div class="soc">
          <a aria-label="Instagram" href={site.social.instagram} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
          <a aria-label="Facebook" href={site.social.facebook} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 8h3V4h-3a4 4 0 00-4 4v2H7v4h3v6h4v-6h3l1-4h-4V8z"/></svg></a>
          <a aria-label="Google Maps" href={site.social.googleMaps} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-7 8-12a8 8 0 10-16 0c0 5 8 12 8 12z"/><circle cx="12" cy="10" r="2.5"/></svg></a>
          <a aria-label="Email" href={`mailto:${site.contact.email}`}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg></a>
          <a aria-label="Phone" href={`tel:${site.contact.phoneIntl}`}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h4l2 5-3 2a12 12 0 005 5l2-3 5 2v4a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z"/></svg></a>
        </div>
      </div>
      <div class="fcol">
        <h5>Information</h5>
        <a href="/medical-cannabis">Medical Cannabis</a>
        <a href="/your-rights">Your Rights</a>
        <a href="/for-police-and-venues">For Police &amp; Venues</a>
        <a href="/blog">Blog &amp; news</a>
      </div>
      <div class="fcol">
        <h5>Membership</h5>
        <a href="/membership">Tiers &amp; benefits</a>
        <a href="/vaping-lounge">Vaping Lounge</a>
        <a href="/shop">Shop</a>
        <a href="/hire">Vape hire · £5</a>
        <a href="/visit">Visit &amp; house rules</a>
        <a href="/about">About</a>
      </div>
      <div class="fcol">
        <h5>Partners &amp; press</h5>
        <a href="/partnerships">Partnerships</a>
        <a href="/visit#contact">Press enquiries</a>
        <a href={site.contact.googleMapsUrl} target="_blank" rel="noopener">{site.contact.address.line1}, {site.contact.address.city} {site.contact.address.postcode}</a>
        <a href={`tel:${site.contact.phoneIntl}`}>{site.contact.phone}</a>
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      </div>
    </div>
    <div class="foot-bottom">
      <div>© {year} Mary Jane's Place — a safe space for medical cannabis patients. We do not sell or supply cannabis.</div>
      <div>Information only — not legal or medical advice.</div>
    </div>
  </div>
</footer>
