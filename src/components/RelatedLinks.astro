---
// Subtle "related content" cross-links shown at the foot of a page.
// Pass a heading and a list of { href, label } items.
interface Item { href: string; label: string; }
interface Props { items?: Item[]; heading?: string; }
const { items = [], heading = "Related" } = Astro.props as Props;
---
{items.length > 0 && (
  <nav class="related" aria-label={heading}>
    <span class="related-h">{heading}</span>
    <ul>
      {items.map((i) => (
        <li><a href={i.href}>{i.label}<span class="related-arr" aria-hidden="true">→</span></a></li>
      ))}
    </ul>
  </nav>
)}

<style>
  .related {
    border-top: 1px solid var(--line);
    margin-top: 8px;
    padding-top: 22px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 18px;
  }
  .related-h {
    font-size: 11.5px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--olive);
  }
  .related ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    margin: 0;
    padding: 0;
  }
  .related a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--olive-d);
    background: var(--tint);
    border: 1px solid var(--line);
    padding: 7px 13px;
    border-radius: 999px;
    transition: 0.18s;
  }
  .related a:hover { border-color: var(--olive); background: var(--panel); }
  .related-arr { color: var(--sage); transition: transform 0.18s; }
  .related a:hover .related-arr { transform: translateX(3px); color: var(--olive); }
  @media (max-width: 680px) {
    .related a { font-size: 13px; padding: 6px 11px; }
  }
</style>
