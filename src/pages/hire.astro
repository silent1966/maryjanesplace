---
import Base from "../layouts/Base.astro";
import RelatedLinks from "../components/RelatedLinks.astro";
---

<Base
  title="Hire — Mary Jane's Place"
  description="Hire a clean, serviced dry-herb vaporiser by the session from £5, or book lounge facilities at Mary Jane's Place. Browse, book a slot, pay on arrival."
>
  <section class="ph-top pad">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Hire</div>
      <h1 class="rv">Hire by the session.</h1>
      <p class="rv lede" style="margin-top:16px">
        Two things to hire here: clean, serviced vaporisers and our lounge facilities.
        Browse, book a slot, pay on arrival.
      </p>
    </div>
  </section>

  <section class="pad-sm" style="padding-top:0">
    <div class="wrap">
      <div class="cat-cards">
        <a class="cat-card rv" href="/book">
          <h3>Vapes &amp; Accessories</h3>
          <p>
            Clean, serviced dry-herb vaporisers and accessories to hire by the session.
            Each device is sanitised between users, with help on hand if you'd like it.
          </p>
          <div class="from">from £5</div>
        </a>
        <a class="cat-card rv" href="/book">
          <h3>Lounge Facilities</h3>
          <p>
            Games tables, outdoor space and cafe seating. More added regularly.
          </p>
          <div class="from">from £5</div>
        </a>
      </div>
      <p class="rv" style="margin-top:16px;font-size:14.5px;color:var(--ink-soft)">
        Facilities expanding regularly — check back for updates.
      </p>
      <a class="btn rv" href="/book" style="margin-top:18px">Book a slot <span class="arr">→</span></a>
      <div class="rv" style="margin-top:26px">
        <RelatedLinks items={[
          { href: "/vaping-lounge", label: "The lounge" },
          { href: "/book", label: "Book a slot" },
          { href: "/shop", label: "Shop devices" },
          { href: "/membership", label: "Become a member" },
        ]} />
      </div>
    </div>
  </section>
</Base>
