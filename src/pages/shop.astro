---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import site from "../content/site/settings.json";

const allProducts = await getCollection("products");
const products = allProducts
  .map((p) => ({ ...p.data, slug: p.id }))
  .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

const categories = [
  { id: "all", label: "All products" },
  { id: "portable-vapes", label: "Portable vapes" },
  { id: "desktop-vapes", label: "Desktop vapes" },
  { id: "pen-vapes", label: "Pen vapes" },
  { id: "dab-pens", label: "Dab pens" },
  { id: "dab-rigs", label: "Concentrate rigs" },
  { id: "cartridge-batteries", label: "510 batteries" },
  { id: "grinders", label: "Grinders" },
  { id: "storage", label: "Storage" },
  { id: "cleaning", label: "Cleaning" },
  { id: "batteries", label: "Batteries" },
  { id: "cases", label: "Cases" },
  { id: "accessories", label: "Accessories" },
].filter((c) => c.id === "all" || products.some((p) => p.category === c.id));

// brands present in the catalogue, for the brand filter dropdown
const brands = [...new Set(products.map((p) => p.brand))].sort((a, b) => a.localeCompare(b));

// price range buckets
const priceRanges = [
  { id: "all", label: "Any price", min: 0, max: Infinity },
  { id: "0-50", label: "£0–50", min: 0, max: 50 },
  { id: "50-150", label: "£50–150", min: 50, max: 150 },
  { id: "150-300", label: "£150–300", min: 150, max: 300 },
  { id: "300+", label: "£300+", min: 300, max: Infinity },
];

const FREE_DELIVERY_OVER = 60;
const totalCount = products.length;
---

<Base
  title="Shop — Vaporisers, grinders and accessories for UK medical cannabis patients · Mary Jane's Place"
  description="The UK shop for prescribed medical cannabis patients. Storz & Bickel, Arizer, DynaVap, PAX, Puffco and more — competitive UK pricing, free delivery over £60, 30-day returns."
>
  <section class="shop-hero pad-sm">
    <div class="wrap">
      <div class="eyebrow kick rv">Shop</div>
      <h1 class="rv" style="margin-bottom:14px">Equipment for prescribed UK patients.</h1>
      <p class="rv lede" style="max-width:64ch">
        Vaporisers, grinders, storage and accessories — hand-picked for medical use,
        priced to match or beat any UK retailer. Free UK delivery over £{FREE_DELIVERY_OVER},
        30-day returns, 18+ verification at checkout.
      </p>
      <div class="rv reassure" style="margin-top:18px">
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg> Authorised UK retailer</span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg> Free delivery over £{FREE_DELIVERY_OVER}</span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg> Secure card payment</span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg> 30-day returns</span>
      </div>
    </div>
  </section>

  <section class="pad-sm" style="padding-top:8px">
    <div class="wrap">
      <div class="shop-controls rv" role="region" aria-label="Filter products">
        <div class="shop-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="search" id="shop-search" placeholder="Search by name, brand or type…" autocomplete="off" aria-label="Search products" />
        </div>

        <div class="cat-scroll" role="tablist" aria-label="Category filter">
          {categories.map((c, i) => (
            <button class:list={["cat-pill", { active: i === 0 }]} data-cat={c.id} type="button" role="tab" aria-selected={i === 0}>
              {c.label}
            </button>
          ))}
        </div>

        <div class="shop-controls-row">
          <div class="price-pills" role="group" aria-label="Price range filter">
            {priceRanges.map((r, i) => (
              <button class:list={["price-pill", { active: i === 0 }]} data-min={r.min} data-max={r.max} type="button">{r.label}</button>
            ))}
          </div>
          <div class="shop-selects">
            <label for="brand-by" class="sr-only">Filter by brand</label>
            <select id="brand-by" class="sort-select">
              <option value="all">All brands</option>
              {brands.map((b) => <option value={b}>{b}</option>)}
            </select>
            <label for="sort-by" class="sr-only">Sort by</label>
            <select id="sort-by" class="sort-select">
              <option value="featured">Featured first</option>
              <option value="price-asc">Price: low to high</option>
              <option value="price-desc">Price: high to low</option>
              <option value="name-asc">Name: A–Z</option>
            </select>
          </div>
        </div>

        <div class="shop-count" id="shop-count" aria-live="polite">Showing {totalCount} of {totalCount} products</div>
      </div>

      <div class="prod-grid" id="prod-grid">
        {products.map((p) => (
          <a
            class="prod-card rv"
            href={`/shop/${p.slug}/`}
            data-cat={p.category}
            data-price={p.price}
            data-name={p.name}
            data-brand={p.brand}
            data-search={`${p.name} ${p.brand} ${(p.tags ?? []).join(" ")}`.toLowerCase()}
            data-featured={p.featured ? "1" : "0"}
            data-order={p.order ?? 999}
          >
            <div class="prod-image">
              {p.featured && <span class="prod-badge">Featured</span>}
              <img src={p.image} alt={p.name} loading="lazy" width="600" height="600" />
            </div>
            <div class="prod-meta">
              <div class="prod-brand">{p.brand}</div>
              <h3 class="prod-name">{p.name}</h3>
              <div class="prod-price">
                {(p.tags ?? []).includes("price-review")
                  ? <span class="price-poa">Price on enquiry</span>
                  : <><span class="price-main">£{p.price.toFixed(2)}</span>
                      {p.salePrice && <span class="price-was">£{p.salePrice.toFixed(2)}</span>}</>
                }
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="empty-state" id="empty-state" style="display:none">
        <p>No products in this category yet — more coming soon.</p>
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap">
      <div class="trust-band rv">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="8" width="18" height="11" rx="2"/><path d="M7 8V6a5 5 0 0110 0v2"/></svg>
          <div>
            <b>Secure checkout</b>
            <span>Card payments via Stripe, encrypted end-to-end. PCI-DSS compliant.</span>
          </div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 7h13l4 4v6h-2a2 2 0 11-4 0H9a2 2 0 11-4 0H3z"/><circle cx="7" cy="17" r="2"/><circle cx="15" cy="17" r="2"/></svg>
          <div>
            <b>Discreet delivery</b>
            <span>Plain packaging, tracked next-day available, dropshipped from NI.</span>
          </div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 0118 0"/><path d="M21 6v6h-6"/><path d="M3 18a9 9 0 0118 0"/></svg>
          <div>
            <b>30-day returns</b>
            <span>Unused, in original packaging. Distance Selling Regulations apply.</span>
          </div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
          <div>
            <b>Authorised stockists</b>
            <span>Genuine product, manufacturer warranties, UK consumer rights.</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const grid = document.getElementById('prod-grid');
  const pills = Array.from(document.querySelectorAll('.cat-pill'));
  const pricePills = Array.from(document.querySelectorAll('.price-pill'));
  const sortSel = document.getElementById('sort-by') as HTMLSelectElement;
  const brandSel = document.getElementById('brand-by') as HTMLSelectElement;
  const searchInput = document.getElementById('shop-search') as HTMLInputElement;
  const empty = document.getElementById('empty-state');
  const countEl = document.getElementById('shop-count');

  let currentCat = 'all';
  let priceMin = 0;
  let priceMax = Infinity;
  const total = grid ? grid.querySelectorAll('.prod-card').length : 0;

  function apply() {
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('.prod-card')) as HTMLAnchorElement[];
    const q = (searchInput?.value || '').trim().toLowerCase();
    const brand = brandSel?.value || 'all';
    let visible = 0;
    cards.forEach((c) => {
      const price = parseFloat(c.dataset.price || '0');
      const matchCat = currentCat === 'all' || c.dataset.cat === currentCat;
      const matchBrand = brand === 'all' || c.dataset.brand === brand;
      const matchPrice = price >= priceMin && price < priceMax;
      const matchSearch = !q || (c.dataset.search || '').includes(q);
      const show = matchCat && matchBrand && matchPrice && matchSearch;
      c.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    if (countEl) countEl.textContent = `Showing ${visible} of ${total} products`;

    const sortKey = sortSel?.value || 'featured';
    const visibleCards = cards.filter((c) => c.style.display !== 'none');
    visibleCards.sort((a, b) => {
      if (sortKey === 'price-asc') return parseFloat(a.dataset.price!) - parseFloat(b.dataset.price!);
      if (sortKey === 'price-desc') return parseFloat(b.dataset.price!) - parseFloat(a.dataset.price!);
      if (sortKey === 'name-asc') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      const aF = parseInt(a.dataset.featured || '0');
      const bF = parseInt(b.dataset.featured || '0');
      if (aF !== bF) return bF - aF;
      return parseInt(a.dataset.order || '999') - parseInt(b.dataset.order || '999');
    });
    visibleCards.forEach((c) => grid.appendChild(c));
  }

  pills.forEach((p) => {
    p.addEventListener('click', () => {
      pills.forEach((x) => { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
      p.classList.add('active');
      p.setAttribute('aria-selected', 'true');
      currentCat = (p as HTMLElement).dataset.cat || 'all';
      apply();
    });
  });
  pricePills.forEach((p) => {
    p.addEventListener('click', () => {
      pricePills.forEach((x) => x.classList.remove('active'));
      p.classList.add('active');
      priceMin = parseFloat((p as HTMLElement).dataset.min || '0');
      priceMax = parseFloat((p as HTMLElement).dataset.max || 'Infinity');
      if (Number.isNaN(priceMax)) priceMax = Infinity;
      apply();
    });
  });
  sortSel?.addEventListener('change', apply);
  brandSel?.addEventListener('change', apply);
  searchInput?.addEventListener('input', apply);

  // deep-link support: /shop?q=foo (from header search / site search action)
  const params = new URLSearchParams(location.search);
  const initialQ = params.get('q');
  if (initialQ && searchInput) searchInput.value = initialQ;

  apply();
</script>

<style>
  .shop-hero { padding-top: 138px; padding-bottom: 24px; }

  .shop-controls {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 22px 0 24px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    border-top: 1px solid var(--line);
    background: var(--paper);
    position: sticky;
    top: 124px;
    z-index: 50;
  }
  .shop-search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .shop-search svg {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--olive);
    pointer-events: none;
  }
  .shop-search input {
    width: 100%;
    font-family: var(--font);
    font-size: 15px;
    padding: 12px 16px 12px 42px;
    border: 1px solid var(--sage-soft);
    border-radius: 10px;
    background: var(--panel);
    color: var(--ink);
  }
  .shop-search input:focus { outline: none; border-color: var(--olive); box-shadow: 0 0 0 3px rgba(85, 107, 47, 0.12); }
  .shop-controls-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .price-pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .price-pill {
    background: var(--panel);
    border: 1px solid var(--sage-soft);
    border-radius: 999px;
    padding: 7px 14px;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-soft);
    cursor: pointer;
    transition: 0.18s;
  }
  .price-pill:hover { color: var(--olive-d); border-color: var(--sage); }
  .price-pill.active { background: var(--olive); color: #fff; border-color: var(--olive); }
  .shop-selects { display: flex; gap: 10px; flex-wrap: wrap; }
  .shop-count { font-size: 13px; font-weight: 600; color: var(--ink-soft); }
  .cat-scroll {
    display: flex;
    flex-wrap: wrap;       /* wrap onto tidy rows on desktop — no scrollbar */
    gap: 8px;
    flex: 1;
    padding: 2px 0;
  }
  .cat-pill {
    flex: none;
    background: var(--panel);
    border: 1px solid var(--sage-soft);
    border-radius: 999px;
    padding: 8px 16px;
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink-soft);
    cursor: pointer;
    transition: 0.18s;
    white-space: nowrap;
  }
  .cat-pill:hover { color: var(--olive-d); border-color: var(--sage); }
  .cat-pill.active { background: var(--olive-d); color: #fff; border-color: var(--olive-d); }
  .sort-select {
    background: var(--panel);
    border: 1px solid var(--sage-soft);
    border-radius: 8px;
    padding: 8px 14px;
    font-family: var(--font);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
  }

  .prod-grid {
    display: grid;
    /* denser, self-adjusting grid — ~5 across on desktop so cards aren't big empty squares */
    grid-template-columns: repeat(auto-fill, minmax(188px, 1fr));
    gap: 16px;
  }
  .prod-card {
    display: block;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--r);
    overflow: hidden;
    transition: 0.22s;
    text-decoration: none;
    color: inherit;
  }
  .prod-card:hover {
    border-color: var(--sage);
    transform: translateY(-4px);
    box-shadow: 0 16px 38px -22px rgba(16, 59, 20, 0.28);
  }
  .prod-image {
    position: relative;
    aspect-ratio: 1 / 0.84;
    background: var(--paper);
    overflow: hidden;
  }
  .prod-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 7px;
    transition: 0.4s;
  }
  .prod-card:hover .prod-image img { transform: scale(1.04); }
  .prod-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--olive-d);
    color: #fff;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 9px;
    border-radius: 5px;
  }
  .prod-meta {
    padding: 14px 16px 18px;
    border-top: 1px solid var(--line);
  }
  .prod-brand {
    font-size: 11.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--olive);
    margin-bottom: 4px;
  }
  .prod-name {
    font-family: var(--font);
    font-size: 15.5px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 8px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .prod-price { display: flex; align-items: baseline; gap: 8px; }
  .price-main { font-size: 17px; font-weight: 800; color: var(--olive-d); letter-spacing: -0.01em; }
  .price-was { font-size: 13.5px; color: var(--ink-soft); text-decoration: line-through; }
  .price-poa { font-size: 14px; font-weight: 700; color: var(--olive); }

  .empty-state {
    padding: 60px 20px;
    text-align: center;
    color: var(--ink-soft);
  }

  .trust-band {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r);
    padding: 26px;
  }
  .trust-item { display: flex; align-items: flex-start; gap: 12px; }
  .trust-item svg { width: 28px; height: 28px; flex: none; color: var(--olive); margin-top: 2px; }
  .trust-item b { display: block; font-size: 14px; font-weight: 700; color: var(--olive-d); margin-bottom: 2px; }
  .trust-item span { font-size: 13px; color: var(--ink-soft); line-height: 1.45; }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }

  @media (max-width: 1100px) {
    .trust-band { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .shop-hero { padding-top: 108px; }
    .shop-controls { flex-direction: column; align-items: stretch; gap: 12px; position: relative; top: 0; }
    /* on phones, swipe-scroll the pills in one row, but hide the scrollbar chrome */
    .cat-scroll { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .cat-scroll::-webkit-scrollbar { display: none; }
    .sort-select { width: 100%; }
    .prod-meta { padding: 12px 14px 16px; }
    .prod-name { font-size: 14.5px; }
    .price-main { font-size: 16px; }
  }
  /* two columns on phones */
  @media (max-width: 620px) {
    .prod-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .prod-meta { padding: 11px 12px 14px; }
    .trust-band { grid-template-columns: 1fr; }
  }
  @media (max-width: 340px) {
    .prod-grid { grid-template-columns: 1fr; }
  }
</style>
