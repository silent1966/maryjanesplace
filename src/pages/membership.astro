---
import Base from "../layouts/Base.astro";
import MemberCard from "../components/MemberCard.astro";
import RelatedLinks from "../components/RelatedLinks.astro";
---

<Base
  title="Membership — Mary Jane's Place"
  description="Free membership for verified UK medical cannabis patients. Access to the lounge, hot food and drinks, equipment hire, loyalty points and members-only events."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What counts as proof of prescription?",
        "acceptedAnswer": { "@type": "Answer", "text": "The dispensing label on your original pharmacy packaging is best. A prescriber letter or a copy of your current prescription also works. We don't need to see your medical history, just enough to confirm you're a prescribed UK patient." }
      },
      {
        "@type": "Question",
        "name": "How do you store loyalty points?",
        "acceptedAnswer": { "@type": "Answer", "text": "On a simple membership card linked to your phone number. Show it at the counter, we tot up your points, you spend them when you like. No app required, no data harvesting." }
      },
      {
        "@type": "Question",
        "name": "Can I bring a non-patient friend in?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Anyone over 18 is welcome to visit and have a drink. Only the act of using your medicine here requires verification. Your friend just can't join in on that side of things." }
      },
      {
        "@type": "Question",
        "name": "What if I lose my prescription paperwork?",
        "acceptedAnswer": { "@type": "Answer", "text": "We can re-verify with any new prescription or dispensing label. Your membership and points roll over. You don't lose anything because life happened." }
      }
    ]
  })} />

  <section class="ph-top pad">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Membership</div>
      <h1 class="rv">Membership.</h1>
      <p class="rv lede" style="margin-top:16px">
        Membership is free for verified prescription patients and gives you access to the
        lounge, hot food and drinks, equipment hire, loyalty points and members-only events.
      </p>
    </div>
  </section>

  <!-- The one public tier -->
  <section class="pad-sm" style="padding-top:0">
    <div class="wrap narrow">
      <div class="rv card tier">
        <div class="eyebrow">Member</div>
        <div class="tier-price"><b>£0</b><span>/ month — free for verified patients</span></div>
        <ul class="checks" style="margin-top:18px">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg><span>Lounge access</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg><span>Hot food &amp; drinks</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg><span>Equipment hire</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg><span>Loyalty points</span></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 6"/></svg><span>Members-only events</span></li>
        </ul>
        <div class="tier-cta" style="display:flex;gap:10px;flex-wrap:wrap">
          <a class="btn" href="/portal">Join online <span class="arr">→</span></a>
          <a class="btn ghost" href="/join">Offline card (no account)</a>
        </div>
        <p class="tier-note">
          <b>Two ways to join, your choice.</b> <b>Online</b> gives you a member portal —
          sign in from any device to see your card, loyalty points and rewards.
          <b>Offline</b> is name-only, saved on your device, with nothing stored on our
          servers. Other options? <a href="/contact">Enquire via Contact</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Member card preview -->
  <section class="pad-sm" style="padding-top:0">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Your card</div>
      <h2 class="rv" style="margin-bottom:18px">A preview of your member card.</h2>
      <div class="rv">
        <MemberCard preview={true} tier="Member" />
      </div>
    </div>
  </section>

  <!-- Verification reassurance -->
  <section class="pad-sm">
    <div class="wrap">
      <div class="callout rv">
        <div>
          <div class="eyebrow">Privacy</div>
          <h3 style="margin-top:6px">Verified once. Never asked again.</h3>
          <p>
            We check your photo ID and proof of prescription one time. We don't keep your
            records, we don't share with clinics or police, and we don't ask what you're
            being treated for.
          </p>
        </div>
        <a class="btn" href="/your-rights">Your rights, in full <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="pad-sm">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Common questions</div>
      <div class="rv" style="margin-top:14px;border-top:1px solid var(--line)">
        <details class="acc-item">
          <summary>What counts as proof of prescription?</summary>
          <div>
            The dispensing label on your original pharmacy packaging is best. A prescriber
            letter or a copy of your current prescription also works. We don't need to see
            your medical history, just enough to confirm you're a prescribed UK patient.
          </div>
        </details>
        <details class="acc-item">
          <summary>How do you store loyalty points?</summary>
          <div>
            On a simple membership card linked to your phone number — show it at the counter,
            we tot up your points, you spend them when you like. No app required, no data
            harvesting. Just numbers next to your name.
          </div>
        </details>
        <details class="acc-item">
          <summary>Can I bring a non-patient friend in?</summary>
          <div>
            Yes — anyone over 18 is welcome to visit and have a drink. Only the act of
            <em>using</em> your medicine here requires verification. Your friend just can't
            join in on that side of things.
          </div>
        </details>
        <details class="acc-item">
          <summary>What if I lose my prescription paperwork?</summary>
          <div>
            We can re-verify with any new prescription or dispensing label. Your membership and
            points roll over — you don't lose anything because life happened.
          </div>
        </details>
      </div>
      <div class="rv" style="margin-top:32px;text-align:center">
        <a class="btn" href="/join">Join <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <section class="pad-sm" style="padding-top:0">
    <div class="wrap narrow">
      <RelatedLinks items={[
        { href: "/join", label: "Join now" },
        { href: "/portal", label: "Member portal" },
        { href: "/vaping-lounge", label: "The lounge" },
        { href: "/visit", label: "Visit us" },
        { href: "/member-card-faq", label: "Member card help" },
      ]} />
    </div>
  </section>
</Base>

<style>
  .tier { background: var(--paper); border-left: 4px solid var(--olive); }
  .tier-price { display: flex; align-items: baseline; gap: 8px; margin-top: 10px; }
  .tier-price b {
    font-size: 48px; font-weight: 800; color: var(--olive-d); line-height: 1; letter-spacing: -0.03em;
  }
  .tier-price span { font-size: 15px; color: var(--ink-soft); }
  .tier-cta { margin-top: 22px; }
  .tier-note { margin-top: 16px; font-size: 14.5px; color: var(--ink-soft); }
  .tier-note a { color: var(--olive); font-weight: 600; text-decoration: underline; }

  .acc-item { border-bottom: 1px solid var(--line); }
  .acc-item summary {
    list-style: none; cursor: pointer; padding: 19px 2px;
    display: flex; justify-content: space-between; gap: 16px; align-items: center;
    font-family: var(--font); font-size: 18px; font-weight: 700; color: var(--olive-d);
  }
  .acc-item summary::-webkit-details-marker { display: none; }
  .acc-item summary::after {
    content: "+"; flex: none; width: 24px; height: 24px; border-radius: 6px;
    border: 1.5px solid var(--line); display: grid; place-items: center;
    transition: 0.25s; font-size: 17px; color: var(--olive); line-height: 1;
  }
  .acc-item[open] summary::after {
    background: var(--olive); border-color: var(--olive); color: #fff; transform: rotate(45deg);
  }
  .acc-item > div { padding: 0 2px 20px; color: var(--ink-soft); font-size: 16px; max-width: 74ch; }
</style>
