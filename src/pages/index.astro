---
import Base from "../layouts/Base.astro";
import site from "../content/site/settings.json";
---

<Base
  title="Mary Jane's Place — A safe space for medical cannabis patients · Bournemouth"
  description="Mary Jane's Place is a members' space in Bournemouth where prescribed medical cannabis patients can use their medicine. Open to verified UK patients. Legal, vaporiser-only, prescription required."
>
  <!-- Speakable schema for voice search assistants -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "url": "https://maryjanesplace.co.uk/",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".sub", "h1", ".lede"]
    },
    "isPartOf": { "@id": "https://maryjanesplace.co.uk/#website" },
    "about": [
      { "@type": "Thing", "name": "Medical cannabis" },
      { "@type": "Thing", "name": "UK medical cannabis prescriptions" },
      { "@type": "Thing", "name": "Dry herb vaporiser lounge" }
    ]
  })} />

  <section class="hero">
    <div class="wrap hero-copy">
      <div class="eyebrow kick rv">Medical Cannabis · Bournemouth</div>
      <h1 class="rv">A safe space for medical cannabis patients.</h1>
      <p class="sub rv">
        A members' lounge in Bournemouth for people with a medical cannabis prescription.
        Somewhere proper to use your medicine — hot food and drinks, equipment hire and games
        on site. Open to verified patients across the UK.
      </p>
      <div class="hero-cta rv">
        <a class="btn" href="/vaping-lounge">See the lounge <span class="arr">→</span></a>
        <a class="btn ghost" href="/membership">Become a member</a>
        <a class="btn ghost" href="/medical-cannabis">Medical cannabis, explained</a>
      </div>
      <div class="reassure rv">
        <span><span class="rb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 3l7 3v5c0 4.4-3 7.7-7 9-4-1.3-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>Legal since 2018</span>
        <span><span class="rb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M20.6 11.4 12 20l-8-8V4h8z"/><circle cx="15.5" cy="8.5" r="1.3" fill="currentColor" stroke="none"/></svg></span>Free for verified patients</span>
        <span><span class="rb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 8h11a3 3 0 100-6"/><path d="M3 14h15a3 3 0 110 6"/><path d="M3 11h7a2.5 2.5 0 100-5"/></svg></span>Medical cannabis lounge</span>
        <span><span class="rb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>Open 7 days a week</span>
      </div>
    </div>
    <a class="scroll-cue" id="scroll-cue" href="#more" aria-label="Scroll for more">
      <span>More below</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </a>
  </section>

  <span id="more"></span>

  <section class="pad">
    <div class="wrap two vc">
      <div class="rv">
        <div class="sec-badge kick"><span class="sb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/></svg></span>What we are</div>
        <h2>The member space for prescribed patients.</h2>
      </div>
      <div class="rv card" style="background:var(--paper);border-left:4px solid var(--olive)">
        <p style="margin-bottom:14px">
          Medical cannabis has been lawfully prescribed in the UK since 2018 — yet patients
          are still refused entry, asked to leave, or made to feel like criminals for using
          a medicine a specialist signed off.
        </p>
        <p>
          Mary Jane's Place is the members' space and safe space for prescribed patients:
          somewhere to use your own medicine through a vaporiser, legally and without hassle,
          alongside clear information and people who get it. We're building it now and growing
          it — getting more patients onto the legal route. We're not a dispensary; we don't
          sell cannabis.
        </p>
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap">
      <div class="sec-badge kick rv"><span class="sb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M8 6h13M8 12h13M8 18h13"/><circle cx="3.5" cy="6" r="1.4" fill="currentColor" stroke="none"/><circle cx="3.5" cy="12" r="1.4" fill="currentColor" stroke="none"/><circle cx="3.5" cy="18" r="1.4" fill="currentColor" stroke="none"/></svg></span>How it works</div>
      <div class="steps" style="margin-top:12px">
        <div class="step rv">
          <div class="n">STEP ONE</div>
          <h3>Hold a prescription</h3>
          <p>You have a valid UK prescription for cannabis-based medicine from a registered specialist clinician.</p>
        </div>
        <div class="step rv">
          <div class="n">STEP TWO</div>
          <h3>Show your prescription</h3>
          <p>Bring proof of a valid prescription (dispensing label or letter). Verified once at the counter.</p>
        </div>
        <div class="step rv">
          <div class="n">STEP THREE</div>
          <h3>Use your medicine</h3>
          <p>Vaporise as prescribed, using your own device or one of ours, in a calm and private setting.</p>
        </div>
      </div>
      <div class="rv callout" style="margin-top:22px">
        <div>
          <div class="eyebrow">Membership</div>
          <h3 style="margin-top:6px">Free — and you're among people who get it.</h3>
          <p>£5 vape hire, 10% off equipment, loyalty points every visit and refer-a-friend
          rewards — plus a community of patients who treat the place, and each other, with respect.</p>
        </div>
        <a class="btn ghost" href="/membership">See all perks <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap">
      <div class="sec-badge kick rv"><span class="sb-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2.2 4.8-4.8 2.2 2.2-4.8z"/></svg></span>Start here</div>
      <h2 class="rv" style="margin-bottom:24px">Clear, honest information.</h2>
      <div class="three">
        <a class="navcard rv" href="/medical-cannabis">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 3h6v4l4 14H5L9 7z"/><path d="M9 13h6"/></svg></div>
          <h3>Medical Cannabis</h3>
          <p>What it is, who can be prescribed it, and how patients use it safely.</p>
          <span class="go">Read more →</span>
        </a>
        <a class="navcard rv" href="/your-rights">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <h3>Your Rights</h3>
          <p>The UK law on possessing, carrying and using your medicine — with the sources.</p>
          <span class="go">Read more →</span>
        </a>
        <a class="navcard rv" href="/visit">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-7 8-12a8 8 0 10-16 0c0 5 8 12 8 12z"/><circle cx="12" cy="10" r="2.5"/></svg></div>
          <h3>Visit Us</h3>
          <p>Where we are, opening hours, what to bring, and the house rules that keep the space safe.</p>
          <span class="go">Read more →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="pad-sm">
    <div class="wrap">
      <div class="band rv">
        <div class="facts">
          {site.facts.map((f) => (
            <div class="fact">
              <div class="big">{f.value}</div>
              <div class="lbl">{f.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  // fade the scroll cue once the visitor starts scrolling
  const cue = document.getElementById('scroll-cue');
  if (cue) {
    const onScroll = () => cue.classList.toggle('hide', window.scrollY > 80);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
