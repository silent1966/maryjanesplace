---
import Base from "../../layouts/Base.astro";
import MemberCard from "../../components/MemberCard.astro";
// This page does two jobs on a static host:
//  1. Returning member ("login"): if a card was saved on this device at sign-up,
//     show it automatically. Otherwise offer a "find your card by Member ID" box.
//  2. Staff verification: when opened with ?id=MJP-2026-NNNN (the QR on the card),
//     show that ID for the member to check against their card.
// v2: a serverless lookup can confirm the ID against a member store and show status.
---

<Base
  title="Your member card — Mary Jane's Place"
  description="View your Mary Jane's Place digital member card on this device, or look it up by Member ID."
>
  <section class="ph-top pad-sm">
    <div class="wrap narrow">
      <div class="eyebrow kick rv">Members</div>
      <h1 class="rv" id="verify-title">Your member card</h1>
      <p class="rv lede" style="margin-top:12px" id="verify-sub">Loading your card…</p>

      <!-- The card (shown for returning members and for QR verification) -->
      <div class="rv" id="verify-card" style="margin-top:22px;display:none">
        <MemberCard preview={false} />
      </div>

      <!-- Member actions (returning member only) -->
      <div class="rv" id="member-actions" style="margin-top:14px;display:none;gap:10px;flex-wrap:wrap">
        <button type="button" class="btn ghost" id="card-pdf">Download as PDF</button>
        <a class="btn ghost" href="/member-card-faq">Add to wallet</a>
        <a class="btn" href="/visit">Plan your visit <span class="arr">→</span></a>
      </div>

      <!-- Find-your-card (no saved card on this device) -->
      <div class="rv" id="find-card" style="margin-top:8px;display:none">
        <form class="mjform" id="find-form">
          <div class="field">
            <label for="find-id">Your Member ID</label>
            <input id="find-id" name="id" type="text" placeholder="MJP-2026-0000" autocomplete="off"
                   inputmode="text" pattern="[Mm][Jj][Pp]-2026-\d{4}" required />
          </div>
          <button class="btn" type="submit">Show my card <span class="arr">→</span></button>
        </form>
        <p class="form-note" style="margin-top:14px">
          Not a member yet? <a href="/join" style="color:var(--olive);font-weight:600">Create your free membership →</a>
        </p>
      </div>

      <p class="rv form-note" id="verify-staff-note" style="margin-top:18px;display:none">
        Staff: check this Member ID against the member's card. Prescription is verified once, in person.
      </p>
    </div>
  </section>
</Base>

<script>
  const params = new URLSearchParams(location.search);
  const urlId = (params.get('id') || '').trim();

  const card = document.getElementById('verify-card') as HTMLElement | null;
  const actions = document.getElementById('member-actions') as HTMLElement | null;
  const find = document.getElementById('find-card') as HTMLElement | null;
  const staffNote = document.getElementById('verify-staff-note') as HTMLElement | null;
  const title = document.getElementById('verify-title');
  const sub = document.getElementById('verify-sub');

  function setQR(id: string) {
    const qr = card?.querySelector('.mcard-qr');
    if (!qr) return;
    const url = 'https://maryjanesplace.co.uk/member?id=' + encodeURIComponent(id);
    qr.innerHTML = '<img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&margin=0&data='
      + encodeURIComponent(url) + '" alt="" width="92" height="92" />';
  }
  function fill(name: string, id: string, joined: string) {
    card?.querySelectorAll('[data-mc-name]').forEach((el) => (el.textContent = name || 'Member'));
    card?.querySelectorAll('[data-mc-id]').forEach((el) => (el.textContent = id));
    card?.querySelectorAll('[data-mc-join]').forEach((el) => (el.textContent = joined || '—'));
    setQR(id);
  }
  function readSaved() {
    try {
      const raw = localStorage.getItem('mjp_member');
      if (!raw) return null;
      const m = JSON.parse(raw);
      if (m && typeof m.id === 'string') return m;
    } catch (e) {}
    return null;
  }

  if (urlId) {
    // --- Staff / QR verification view ---
    const valid = /^MJP-2026-\d{4}$/i.test(urlId);
    if (title) title.textContent = 'Member card';
    if (sub) sub.textContent = valid
      ? ('Verifying member ' + urlId.toUpperCase())
      : ('Unrecognised ID format: ' + urlId);
    // If the scanned ID matches the saved card on THIS device, show the real name.
    const saved = readSaved();
    if (saved && String(saved.id).toUpperCase() === urlId.toUpperCase()) {
      fill(saved.name, urlId.toUpperCase(), saved.joinDate || '');
    } else {
      fill('Member', urlId.toUpperCase(), '—');
    }
    if (card) card.style.display = 'block';
    if (staffNote) staffNote.style.display = 'block';
  } else {
    // --- Returning member ("login") view ---
    const saved = readSaved();
    if (saved) {
      if (title) title.textContent = 'Your member card';
      if (sub) sub.textContent = 'Saved on this device — show this at the counter on your visit.';
      fill(saved.name, saved.id, saved.joinDate || '');
      if (card) card.style.display = 'block';
      if (actions) actions.style.display = 'flex';
    } else {
      if (title) title.textContent = 'Find your member card';
      if (sub) sub.textContent = 'Enter your Member ID to show your card, or join in under a minute.';
      if (find) find.style.display = 'block';
    }
  }

  // Find-by-ID: reload with ?id= so the card renders (and is bookmarkable).
  document.getElementById('find-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('find-id') as HTMLInputElement | null;
    const id = (input?.value || '').trim().toUpperCase();
    if (/^MJP-2026-\d{4}$/.test(id)) location.search = '?id=' + encodeURIComponent(id);
  });

  document.getElementById('card-pdf')?.addEventListener('click', () => window.print());
</script>
